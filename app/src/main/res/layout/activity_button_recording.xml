<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Record Target Button"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tv_instructions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:layout_marginBottom="24dp" />

    <TextView
        android:id="@+id/tv_current_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#11000000"
        android:padding="12dp"
        android:textSize="14sp"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btn_select_app"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Select target app"
        android:layout_marginBottom="12dp"
        style="@style/Widget.Material3.Button.OutlinedButton" />

    <Button
        android:id="@+id/btn_start_recording"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Record button"
        android:enabled="false"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btn_preview_tap"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Preview tap location"
        android:layout_marginBottom="12dp"
        style="@style/Widget.Material3.Button.OutlinedButton" />

    <Button
        android:id="@+id/btn_clear_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Clear recorded button"
        style="@style/Widget.Material3.Button.OutlinedButton" />

</LinearLayout>
